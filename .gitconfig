[user]
email = tmg.7@icloud.com
name = Tom Garcia
signingkey = 0x8B4A6A4401C3462B
[commit]
gpgsign = true

[color]
diff = auto
status = auto
branch = auto
interactive = auto
ui = true
pager = true

[alias]
lg = log --graph --all

[github]
user = 7onn

[core]
excludesfile = ~/.gitignore_global

[push]
default = simple

[filter "lfs"]
required = true
clean = git-lfs clean -- %f
smudge = git-lfs smudge -- %f
process = git-lfs filter-process
[pull]
	rebase = true
[init]
defaultBranch = main
